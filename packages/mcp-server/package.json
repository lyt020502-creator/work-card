{
  "name": "@lyt020502-creator/work-card-mcp-server",
  "version": "2.3.0",
  "type": "module",
  "description": "MCP Server for Work Card component library",
  "bin": {
    "work-card-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "prebuild": "node scripts/copy-assets.js",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "zod": "^3.23.0"
  }
}
